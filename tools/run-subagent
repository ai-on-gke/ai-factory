#!/usr/bin/env python3
import sys
import os
import re
import subprocess
import textwrap

def main():
    if len(sys.argv) < 2:
        print(f"Usage: {sys.argv[0]} <agent-name> [schedule]")
        print(f"Example: {sys.argv[0]} my-agent '0 */8 * * *'")
        print(f"Example: {sys.argv[0]} my-agent 'every 8 hours'")
        sys.exit(1)

    agent_name = sys.argv[1]
    schedule = sys.argv[2] if len(sys.argv) > 2 else None

    project_id = os.environ.get("GCP_PROJECT_ID", "my-project")
    agent_image = f"gcr.io/{project_id}/ai-on-gke-agent:latest"

    cron_schedule = schedule
    if schedule:
        # Helper to convert some basic natural language schedules to cron
        # e.g., "every 8 hours" -> "0 */8 * * *"
        m = re.match(r'^every\s+([0-9]+)\s+hours?$', schedule)
        if m:
            cron_schedule = f"0 */{m.group(1)} * * *"
        else:
            m = re.match(r'^every\s+([0-9]+)\s+minutes?$', schedule)
            if m:
                cron_schedule = f"*/{m.group(1)} * * * *"
            else:
                m = re.match(r'^every\s+([0-9]+)\s+days?$', schedule)
                if m:
                    cron_schedule = f"0 0 */{m.group(1)} * *"
                elif schedule == "daily":
                    cron_schedule = "0 0 * * *"
                elif schedule == "hourly":
                    cron_schedule = "0 * * * *"

    if not schedule:
        print(f"Running agent {agent_name} immediately...")
        yaml_content = textwrap.dedent(f"""\
            apiVersion: agents.x-k8s.io/v1alpha1
            kind: Sandbox
            metadata:
              generateName: {agent_name}-sandbox-
              labels:
                agent: {agent_name}
            spec:
              podTemplate:
                spec:
                  containers:
                  - name: agent
                    image: {agent_image}
                    env:
                    - name: AGENT_NAME
                      value: {agent_name}
                  restartPolicy: Never
            """)
        
        process = subprocess.run(["kubectl", "create", "-f", "-"], input=yaml_content, text=True)
        if process.returncode == 0:
            print("Sandbox creation requested.")
        else:
            sys.exit(process.returncode)
    else:
        print(f"Scheduling agent {agent_name} with schedule: {cron_schedule}...")
        
        yaml_content = textwrap.dedent(f"""\
            apiVersion: batch/v1
            kind: CronJob
            metadata:
              name: {agent_name}-scheduler
              labels:
                agent: {agent_name}
            spec:
              schedule: "{cron_schedule}"
              jobTemplate:
                spec:
                  template:
                    spec:
                      serviceAccountName: top-level-agent-sa
                      containers:
                      - name: kubectl
                        image: bitnami/kubectl:latest
                        command:
                        - /bin/sh
                        - -c
                        - |
                          cat <<INNERYAML | kubectl create -f -
                          apiVersion: agents.x-k8s.io/v1alpha1
                          kind: Sandbox
                          metadata:
                            generateName: {agent_name}-sandbox-
                            labels:
                              agent: {agent_name}
                          spec:
                            podTemplate:
                              spec:
                                containers:
                                - name: agent
                                  image: {agent_image}
                                  env:
                                  - name: AGENT_NAME
                                    value: {agent_name}
                                restartPolicy: Never
                          INNERYAML
                      restartPolicy: OnFailure
            """)
            
        process = subprocess.run(["kubectl", "apply", "-f", "-"], input=yaml_content, text=True)
        if process.returncode == 0:
            print("CronJob scheduler created.")
        else:
            sys.exit(process.returncode)

if __name__ == "__main__":
    main()
