#!/usr/bin/env python3
import sys
import os
import subprocess
import textwrap

def main():
    if len(sys.argv) < 2:
        print(f"Usage: {sys.argv[0]} <agent-name>")
        print(f"Example: {sys.argv[0]} my-agent")
        sys.exit(1)

    agent_name = sys.argv[1]

    project_id = os.environ.get("GCP_PROJECT_ID", "my-project")
    agent_image = f"gcr.io/{project_id}/ai-on-gke-agent:latest"

    print(f"Running agent {agent_name}...")
    yaml_content = textwrap.dedent(f"""\
        apiVersion: agents.x-k8s.io/v1alpha1
        kind: Sandbox
        metadata:
          name: {agent_name}-sandbox
          labels:
            agent: {agent_name}
        spec:
          podTemplate:
            spec:
              containers:
              - name: agent
                image: {agent_image}
                env:
                - name: AGENT_NAME
                  value: {agent_name}
                - name: GEMINI_SERVICE_PORTAL
                  value: "http://gemini-portal:80"
                - name: GEMINI_SERVICE_PORTAL_CA_CERTS
                  value: "/etc/ssl/certs/gemini-portal-ca.crt"
                volumeMounts:
                - name: ca-cert
                  mountPath: /etc/ssl/certs/gemini-portal-ca.crt
                  subPath: tls.crt
              volumes:
              - name: ca-cert
                secret:
                  secretName: gemini-portal-ca
              restartPolicy: Always
        """)
    
    process = subprocess.run(["kubectl", "apply", "-f", "-"], input=yaml_content, text=True)
    if process.returncode == 0:
        print("Sandbox creation requested.")
    else:
        sys.exit(process.returncode)

if __name__ == "__main__":
    main()
